{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Failpath",
  "theme": "luma",
  "logo": {
    "light": "/images/logo.png",
    "dark": "/images/logo.png"
  },
  "favicon": "/images/failpath-favicon.svg",
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#fbfbfc",
      "dark": "#050506"
    }
  },
  "colors": {
    "primary": "#3f3f46",
    "light": "#52525b",
    "dark": "#d4d4d8"
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": "dark"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/failpath"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "introduction",
          "quickstart"
        ]
      },
      {
        "group": "Core Concepts",
        "pages": [
          "concepts/flows",
          "concepts/runs-and-steps",
          "concepts/events"
        ]
      },
      {
        "group": "CLI",
        "pages": [
          "cli/overview",
          "cli/commands",
          "cli/configuration"
        ]
      },
      {
        "group": "SDK",
        "pages": [
          "sdk/overview",
          "sdk/typed-keys",
          "sdk/client",
          "sdk/runs-and-steps",
          "sdk/testing",
          "sdk/options"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/instrument-a-flow",
          "guides/metadata",
          "guides/error-handling",
          "guides/environments"
        ]
      }
    ]
  }
}
