{
  "projectType": "sdk-library",
  "projectName": "Failpath",
  "projectDescription": "Failpath lets you define flows with the CLI, instrument your backend with the SDK, and monitor runtime step events on a live dashboard.",
  "theme": "luma",
  "primaryColor": "#241c24",
  "lightColor": "#f4f4f4",
  "darkColor": "#cb0404",
