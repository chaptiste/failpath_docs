  },
  "keyFeatures": [
    "Define and publish flow graphs from your repository using the CLI",
    "Instrument backend functions with step-level event recording",
    "Automatic success/error status tracking per step",
    "Rich metadata attachment to runs and steps",
    "Skip steps explicitly without recording errors",
    "Low-overhead fire-and-forget telemetry (never throws by default)",
    "TypeScript-first SDK with built-in type declarations"
  ],
  "publicApiSurface": [
    "createFailpathClient(options)",
    "failpath.run(flowKey, options)",
    "run.step(stepKey, fn, options)",
    "run.skip(stepKey)",
    "failpath.recordStep(options)",
    "npx failpath init --project-key",
    "npx failpath publish",
    "npx failpath sync",
    "FAILPATH_PROJECT_KEY env var"
  ]
}
